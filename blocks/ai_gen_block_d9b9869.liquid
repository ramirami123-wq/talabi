{% doc %}
  @prompt
    please  make for me a us vs others table 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
  }

  .ai-comparison-table__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 40px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    border-radius: {{ block.settings.table_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    width: 40%;
  }

  .ai-comparison-table__us-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.us_column_background }};
    color: {{ block.settings.us_column_text_color }};
    position: relative;
  }

  .ai-comparison-table__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    margin-left: 8px;
    text-transform: uppercase;
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: 16px 20px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-comparison-table__us-cell-{{ ai_gen_id }} {
    background-color: {{ block.settings.us_cell_background }};
    font-weight: 600;
  }

  .ai-comparison-table__check-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: {{ block.settings.check_background }};
  }

  .ai-comparison-table__check-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.check_color }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: {{ block.settings.cross_background }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      padding: 12px 8px;
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }} {
      padding: 12px 8px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-comparison-table__badge-{{ ai_gen_id }} {
      display: block;
      margin: 4px 0 0;
    }
  }
{% endstyle %}

<comparison-table-{{ ai_gen_id }}
  class="ai-comparison-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-comparison-table__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead class="ai-comparison-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">
            {{ block.settings.feature_column_label }}
          </th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }} ai-comparison-table__us-header-{{ ai_gen_id }}">
            {{ block.settings.us_column_label }}
            {% if block.settings.show_badge %}
              <span class="ai-comparison-table__badge-{{ ai_gen_id }}">
                {{ block.settings.badge_text }}
              </span>
            {% endif %}
          </th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">
            {{ block.settings.others_column_label }}
          </th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign us_key = 'us_' | append: i
            assign others_key = 'others_' | append: i

            assign feature = block.settings[feature_key]
            assign us_value = block.settings[us_key]
            assign others_value = block.settings[others_key]
          %}

          {% if feature != blank %}
            <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
              <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
                {{ feature }}
              </td>
              <td class="ai-comparison-table__cell-{{ ai_gen_id }} ai-comparison-table__us-cell-{{ ai_gen_id }}">
                {% if us_value == 'check' %}
                  <span class="ai-comparison-table__check-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif us_value == 'cross' %}
                  <span class="ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ us_value }}
                {% endif %}
              </td>
              <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
                {% if others_value == 'check' %}
                  <span class="ai-comparison-table__check-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif others_value == 'cross' %}
                  <span class="ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ others_value }}
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</comparison-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ComparisonTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('comparison-table-{{ ai_gen_id }}', ComparisonTable{{ ai_gen_id }});
  })();
</script>

